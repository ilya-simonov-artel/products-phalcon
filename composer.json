{
  "name": "openai/phalcon-test",
  "description": "Product catalog service on Phalcon with MySQL, Vue 3 and Docker",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-phalcon": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phalcon/ide-stubs": "5.*"
  }
}
